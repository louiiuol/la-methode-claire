	"scripts": {
		"start": "nx serve",
		"serve:api": "nx run lmc-api:serve",
		"serve:app:ui": "nx run lmc-app-ui:serve",
		"serve:admin:ui": "nx run lmc-admin-ui:serve",
		"serve:public:ui": "nx run lmc-public-ui:serve",
		"serve:apps": "concurrently \" npm run serve:api \" \" npm run serve:app:ui \" \" npm run serve:admin:ui \"",
		"build": "nx run-many --target=build --all --parallel",
		"test": "nx run-many --target=test --all --parallel",
		"lint": "nx run-many --target=lint --all --parallel",
		"e2e": "nx run-many --target=e2e --all --parallel",
